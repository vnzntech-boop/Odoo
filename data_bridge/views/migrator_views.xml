<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Migrator List View -->
    <record id="view_migrator_list" model="ir.ui.view">
        <field name="name">migrator.migrator.list</field>
        <field name="model">migrator.migrator</field>
        <field name="arch" type="xml">
            <list string="Batch Details">
                <field name="migration_id"/>
                <field name="batch" string="No"/>
                <field name="data_range"/>
                <field name="limit"/>
                <field name="offset"/>
                <field name="duration" widget="float_time"/>
                <button name="action_view_details" string="See Values" type="object" class="btn-primary" icon="fa-list"/>
            </list>
        </field>
    </record>

    <!-- Migrator Form View -->
    <record id="view_migrator_form" model="ir.ui.view">
        <field name="name">migrator.migrator.form</field>
        <field name="model">migrator.migrator</field>
        <field name="arch" type="xml">
            <form string="Batch Detail">
                <header>
                    <button name="action_view_details" string="See Values" type="object" class="btn-primary" icon="fa-list" invisible="not migrated_record_ids"/>
                </header>
                <sheet >
                    <group>
                        <group>
                            <field name="migration_id"/>
                            <field name="batch" string="Batch Number"/>
                            <field name="data_range"/>
                        </group>
                        <group>
                            <field name="limit"/>
                            <field name="offset"/>
                            <field name="duration" widget="float_time"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Migrator Action -->
    <record id="action_migrator_batch" model="ir.actions.act_window">
        <field name="name">Batch Details</field>
        <field name="res_model">migrator.migrator</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No batches generated yet.
            </p>
            <p>
                Batches are automatically generated when you analyze a migration model.
            </p>
        </field>
    </record>
</odoo>
