<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- API Migration Form View -->
    <record id="view_api_migration_form" model="ir.ui.view">
        <field name="name">data.bridge.api.migration.form</field>
        <field name="model">data.bridge.api.migration</field>
        <field name="arch" type="xml">
            <form string="API Migration">
                <header>
                    <button name="action_test_connection" type="object" 
                            string="Test Connection" class="btn-primary"
                            invisible="state not in ['draft', 'error']"
                            icon="fa-plug"/>
                    <button name="get_models_data" type="object"
                            string="1. Get Model Data &amp; Analyze" class="btn-primary"
                            invisible="state != 'connected'"
                            icon="fa-search"/>

                    <button name="action_ready" type="object"
                            string="Ready" class="btn-primary"
                            invisible="state != 'connected'"
                            icon="fa-check"/>
                    <button name="reset_to_connected" type="object"
                            string="Re-Analyze Fields" class="btn-secondary"
                            invisible="state not in ['running']"
                            icon="fa-refresh"/>
                    <button name="load_steps"
                            type="object"
                            string="Load Steps"
                            class="btn-primary"
                            icon="fa-search"
                            invisible="state != 'ready' or migrator_ids"/>

                    
                    <field name="state" widget="statusbar" 
                           statusbar_visible="draft,connected,ready,running,done"/>
                </header>
                <sheet>
                    
                    
                    <widget name="web_ribbon" title="Running..." bg_color="bg-info" 
                            invisible="state != 'running'"/>
                    <widget name="web_ribbon" title="Completed" bg_color="bg-success" 
                            invisible="state != 'done'"/>
                    <widget name="web_ribbon" title="Error" bg_color="bg-danger" 
                            invisible="state != 'error'"/>
                    
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Migration Name"/>
                        </h1>
                    </div>
                    
                    
                    <group>
                        <group string="Old ERP Connection">
                            <field name="erp_url" placeholder="https://old-erp.example.com"
                                   widget="url" readonly="not (state == 'draft' or state == 'connected')"/>
                            <field name="erp_db" placeholder="old_database" readonly="not (state == 'draft' or state == 'connected')"  />
                            <field name="erp_username" placeholder="admin@example.com" readonly="not (state == 'draft' or state == 'connected')"/>
                            <field name="erp_password" password="True" readonly="not (state == 'draft' or state == 'connected')"/>
                            <field name="erp_uid" invisible="erp_uid == 0"/>
                        </group>
                        <group string="Model Configuration">
                            <field name="source_model" placeholder="res.partner" readonly="not (state == 'draft' or state == 'connected')"    />
                            <field name="destination_model_id" required = "1" readonly="not (state == 'draft' or state == 'connected')"/>
                            <field name="domain_filter" placeholder="[('active', '=', True)]" readonly="not (state == 'draft' or state == 'connected')"/>
                            <div colspan="2" class="alert alert-warning mt-2 mb-0" role="alert">
                                 <i class="fa fa-exclamation-triangle"/> Apply a domain filter to exclude unnecessary records and optimize the migration process.
                            </div>
                        </group>
                    </group>
                    
                    <group>
                        <group string="Options">
                            <field name="batch_size" readonly="not (state == 'draft' or state == 'connected')"/>
                            <!-- <field name="offset"/> -->

                            <field name="skip_errors" readonly="not (state == 'draft' or state == 'connected')"/>
                            <field name="enable_create" readonly="not (state == 'draft' or state == 'connected')"/>
                        </group>
                        <group string="Statistics" invisible="not total_source_records">
                            <field name="total_source_records"/>
                            <field name="total_batches"/>
                            <field name="migration_duration" widget="float_time" />
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Status" name="status" invisible="state not in ['running', 'done', 'error']">
                            <div class="alert alert-info" role="alert">
                                <div class="row text-center">
                                    <div class="col-md-3">
                                        <div class="border rounded p-2 bg-white">
                                            <h4 class="text-success mb-0">
                                                <field name="migrated_records" readonly="1"/>
                                            </h4>
                                            <small class="text-muted">Created</small>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="border rounded p-2 bg-white">
                                            <h4 class="text-danger mb-0">
                                                <field name="failed_records" readonly="1"/>
                                            </h4>
                                            <small class="text-muted">Failed</small>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="border rounded p-2 bg-white">
                                            <h4 class="text-warning mb-0">
                                                <field name="skipped_records" readonly="1"/>
                                            </h4>
                                            <small class="text-muted">Skipped</small>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="border rounded p-2 bg-white">
                                            <h4 class="text-info mb-0">
                                                <field name="records_per_second" readonly="1"/> /s
                                            </h4>
                                            <small class="text-muted">Speed</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mt-2" invisible="state != 'running'">
                                    <div class="col-12 text-center">
                                        <span class="text-muted">
                                            Batch <field name="current_batch" readonly="1"/> of 
                                            <field name="total_batches" readonly="1"/>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </page>

                        <page string="Field Mapping" name="field_mapping" invisible="state == 'draft'">
                            <div class="alert alert-info d-flex align-items-center justify-content-between mb-3" role="alert">
                                <div>
                                    <i class="fa fa-info-circle me-2"/> 
                                    All fields available in the source ERP model. Map them to destination fields:
                                </div>
                                <button name="action_auto_update_mappings" type="object"
                                        string="Auto Update Mappings" class="btn btn-primary btn-sm"
                                        icon="fa-magic" help="Automatically map all fields by name and type"/>
                            </div>
                            <field name="field_mapping_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="field_name" optional="hide" readonly="1"/>
                                    <field name="field_label" readonly="1"/>
                                    <field name="field_type" readonly="1" string="Type"/>
                                    <field name="restore_to_id" 
                                           domain="[('model_id', '=', parent.destination_model_id)]"
                                           options="{'no_create': True}"/>
                                    <field name="restore_to_type" readonly="1" string="Type"/>
                                    <!-- <button name="action_auto_update" type="object" 
                                            string="Auto Update" icon="fa-refresh" 
                                            class="btn-link" title="Auto Map Field"/> -->
                                </list>
                            </field>
                        </page>
                        <page string="Batches/Migrators" name="migrators" invisible="state == 'draft'">
                            <field name="migrator_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="batch" string="No"/>
                                    <field name="data_range"/>
                                    <field name="limit"/>
                                    <field name="offset"/>
                                    <field name="migrated_record_ids" optional="hide"/>
                                    <field name="duration" widget="float_time"/>
                                    <field name="is_done" column_invisible="True"/>
                                    <field name="is_update_all_clicked" column_invisible="True"/>
                                    <field name="is_update_normal_clicked" column_invisible="True"/>
                                    <field name="is_update_m2o_clicked" column_invisible="True"/>
                                    <field name="is_update_m2m_clicked" column_invisible="True"/>
                                    <field name="is_update_o2m_clicked" column_invisible="True"/>

                                    <button name="action_update_all" type="object" 
                                            string="Update All" class="btn-success"
                                            icon="fa-magic" style="min-width: 130px;"
                                            invisible="is_update_all_clicked or is_update_normal_clicked"/>

                                    <button name="action_invisible_btn" type="object" 
                                            string=" " class="btn-link text-white bg-white"
                                            style="pointer-events: none; cursor: default; border: none; min-width: 50px;"/>
                                    <button name="action_invisible_btn" type="object" 
                                            string=" " class="btn-link text-white bg-white"
                                            style="pointer-events: none; cursor: default; border: none; min-width: 50px;"/>
                                    <button name="action_invisible_btn" type="object" 
                                            string=" " class="btn-link text-white bg-white"
                                            style="pointer-events: none; cursor: default; border: none; min-width: 50px;"/>

                                    <button name="action_update_normal" type="object" 
                                            string="Update Normal" class="btn-primary"
                                            icon="fa-play" style="min-width: 130px;"
                                            invisible="is_update_all_clicked or is_update_normal_clicked or '1'=='1'"/>
                                    <button name="action_update_many2one_fields" type="object" 
                                            string="Update M2O" class="btn-info"
                                            icon="fa-link" style="min-width: 130px;"
                                            invisible="is_update_all_clicked or is_update_m2o_clicked or '1'=='1'"/>
                                    <button name="action_update_many2many_fields" type="object" 
                                            string="Update M2M" class="btn-warning"
                                            icon="fa-link" style="min-width: 130px;"
                                            invisible="is_update_all_clicked or is_update_m2m_clicked or '1'=='1'"/>
                                    <button name="action_update_one2many_fields" type="object" 
                                            string="Update O2M's" class="btn-secondary"
                                            icon="fa-list" style="min-width: 130px;"
                                            invisible="is_update_o2m_clicked"/>

                                    <button name="action_view_details" type="object" 
                                            string="See All" class="btn-primary"
                                            icon="fa-list" style="min-width: 100px;"
                                            invisible="not migrated_record_ids"/>
                                </list>
                            </field>
                        </page>
                        
                        <page string="Fields to Migrate" invisible="1" name="included_fields">
                            <div class="alert alert-success mb-3">
                                <i class="fa fa-check-circle"/> These fields will be migrated:
                            </div>
                            <field name="included_fields" readonly="1" nolabel="1"
                                   widget="text" placeholder="No fields analyzed yet..."/>
                        </page>
                        <page string="Excluded Fields" invisible="1" name="excluded_fields">
                            <div class="alert alert-warning mb-3">
                                <i class="fa fa-exclamation-triangle"/> These fields will be skipped 
                                (Many2many, Many2one, One2many, system fields):
                            </div>
                            <field name="excluded_fields" readonly="1" nolabel="1"/>
                        </page>
                        <page string="Notes" invisible="state == 'draft'" name="notes">
                            <field name="notes" placeholder="Additional notes..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- API Migration list View -->
    <record id="view_api_migration_list" model="ir.ui.view">
        <field name="name">data.bridge.api.migration.list</field>
        <field name="model">data.bridge.api.migration</field>
        <field name="arch" type="xml">
            <list string="API Migrations" decoration-info="state == 'running'"
                  decoration-success="state == 'done'"
                  decoration-danger="state == 'error'">
                <field name="name"/>
                <field name="erp_url" widget="url" optional="show"/>
                <field name="source_model"/>
                <!-- <field name="destination_model" optional="show"/> -->
                <field name="total_source_records" optional="show"/>
                <field name="migrated_records"/>
                <field name="failed_records" decoration-danger="failed_records > 0" optional="show"/>
                <field name="state" widget="badge" 
                       decoration-success="state == 'done'"
                       decoration-info="state in ['connected', 'ready', 'running']"
                       decoration-danger="state == 'error'"
                       decoration-muted="state == 'draft'"/>
                <field name="last_migration_date" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- API Migration Kanban View -->
    <record id="view_api_migration_kanban" model="ir.ui.view">
        <field name="name">data.bridge.api.migration.kanban</field>
        <field name="model">data.bridge.api.migration</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="state">
                <field name="name"/>
                <field name="state"/>
                <field name="source_model"/>
                <field name="total_source_records"/>
                <field name="migrated_records"/>
                <field name="failed_records"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_title">
                                    <strong><field name="name"/></strong>
                                </div>
                                <div class="o_kanban_record_subtitle text-muted">
                                    <field name="source_model"/> → <field name="destination_model"/>
                                </div>
                                <div class="row mt-2">
                                    <div class="col-4 text-center">
                                        <span class="text-muted">Total</span><br/>
                                        <strong><field name="total_source_records"/></strong>
                                    </div>
                                    <div class="col-4 text-center">
                                        <span class="text-success">Created</span><br/>
                                        <strong class="text-success"><field name="migrated_records"/></strong>
                                    </div>
                                    <div class="col-4 text-center">
                                        <span class="text-danger">Failed</span><br/>
                                        <strong class="text-danger"><field name="failed_records"/></strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>


    <!-- API Migration Action -->
    <record id="action_api_migration" model="ir.actions.act_window">
        <field name="name">API Migration</field>
        <field name="res_model">data.bridge.api.migration</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first API migration
            </p>
            <p>
                Connect to your old Odoo ERP and migrate data to your current instance.
            </p>
            <p class="text-muted">
                <i class="fa fa-info-circle"/> Many2many and One2many fields are automatically excluded.
            </p>
        </field>
    </record>

</odoo>
